{
  "include": [
    "./**/*.py"
  ],
  "exclude": [
    "**/venv*/**",
    "**/.venv/**",
    "**/env/**",
    "**/site-packages/**",
    "**/__pycache__/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.pytest_cache/**",
    "**/.deprecated/**",
    "**/contents_class_def/**", 
    "**/node_modules", 
    "**/.*", 
    "venv-alarm312"
  ],
  "typeCheckingMode": "strict",
  "useLibraryCodeForTypes": true,
  "reportMissingTypeStubs": false,
  "reportUnusedImport": false,
  "reportUnusedVariable": false
}