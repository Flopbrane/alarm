digraph G {
rankdir=LR;
graph [overlap=false, splines=true, nodesep=0.55, ranksep=1.0];
node [shape=ellipse, style=filled, fillcolor=white, fontsize=10];
edge [penwidth=1.4];
subgraph cluster_helper_misc {
label="helper_misc";
style=filled;
fillcolor=lightgray;
"tick" [shape=ellipse, fillcolor=white];
"internal_clock" [shape=ellipse, fillcolor=white];
"_where" [shape=ellipse, fillcolor=white];
"get_alarm_by_id" [shape=ellipse, fillcolor=white];
"_handle_due_alarms" [shape=ellipse, fillcolor=white];
"get_next_alarms" [shape=ellipse, fillcolor=white];
"apply_alarm_mutation" [shape=ellipse, fillcolor=white];
"_add_alarm" [shape=ellipse, fillcolor=white];
"_remove_alarms_by_ids" [shape=ellipse, fillcolor=white];
"stop_alarm" [shape=ellipse, fillcolor=white];
"needs_migration" [shape=ellipse, fillcolor=white];
"create_alarm" [shape=ellipse, fillcolor=white];
}
subgraph cluster_runtime {
label="runtime";
style=filled;
fillcolor=moccasin;
"_recalc_states" [shape=ellipse, fillcolor=white];
"_update_next_fire_runtime" [shape=ellipse, fillcolor=white];
"_repair_invalid_states" [shape=ellipse, fillcolor=white];
"_update_alarm" [shape=ellipse, fillcolor=white];
}
subgraph cluster_config_state {
label="config_state";
style=filled;
fillcolor=lavender;
"_get_state" [shape=ellipse, fillcolor=white];
"_get_or_create_state" [shape=ellipse, fillcolor=white];
"_normalize_on_boot_and_edit" [shape=ellipse, fillcolor=white];
"_ensure_state_id_integrity" [shape=ellipse, fillcolor=white];
"_normalize_for_persistence" [shape=ellipse, fillcolor=white];
"_normalize_alarms_by_id" [shape=ellipse, fillcolor=white];
}
subgraph cluster_fire_notify {
label="fire_notify";
style=filled;
fillcolor=lightpink;
"_fire_alarm" [shape=ellipse, fillcolor=white];
}
subgraph cluster_phase_core {
label="phase_core";
style=filled;
fillcolor=lightgoldenrod1;
"_check_invalid_states" [shape=box, fillcolor=white];
"_notify_listeners" [shape=box, fillcolor=white];
"_begin_cycle" [shape=box, fillcolor=white];
"_load_phase" [shape=box, fillcolor=white];
"_recalc_phase" [shape=box, fillcolor=white];
"_fire_phase" [shape=box, fillcolor=white];
"_save_phase" [shape=box, fillcolor=white];
"_stop_phase" [shape=box, fillcolor=white];
}
subgraph cluster_runtime_index {
label="runtime_index";
style=filled;
fillcolor=khaki1;
"build_alarm_fingerprint" [shape=ellipse, fillcolor=white];
}
subgraph cluster_storage {
label="storage";
style=filled;
fillcolor=palegreen;
"load_alarms" [shape=ellipse, fillcolor=white];
"load_standby" [shape=ellipse, fillcolor=white];
"load_all" [shape=ellipse, fillcolor=white];
"save" [shape=ellipse, fillcolor=white];
"save_standby" [shape=ellipse, fillcolor=white];
}
subgraph cluster_public_api {
label="public_api";
style=filled;
fillcolor=lightskyblue;
"start_cycle" [shape=box, fillcolor=white];
"run_cycle" [shape=box, fillcolor=white];
}
subgraph cluster_cycle_control {
label="cycle_control";
style=filled;
fillcolor=lightcyan;
"_start_config_changed_cycle" [shape=ellipse, fillcolor=white];
"_start_startup_cycle" [shape=ellipse, fillcolor=white];
"_start_running_cycle" [shape=ellipse, fillcolor=white];
}
